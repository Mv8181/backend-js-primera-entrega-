

<h1>Real Time Products</h1>

<h2>Agregar producto (WebSocket)</h2>
<form id="addForm">
  <input name="title" placeholder="title" required />
  <input name="description" placeholder="description" required />
  <input name="code" placeholder="code" required />
  <input name="price" type="number" placeholder="price" required />
  <input name="stock" type="number" placeholder="stock" required />
  <input name="category" placeholder="category" required />
  <input name="thumbnails" placeholder='thumbnails (ej: /img/a.png,/img/b.png)' required />

  <label>
    status
    <input name="status" type="checkbox" checked />
  </label>

  <button type="submit">Agregar</button>
</form>

<h2>Eliminar producto (WebSocket)</h2>
<form id="deleteForm">
  <input name="pid" type="number" placeholder="ID del producto" required />
  <button type="submit">Eliminar</button>
</form>

<hr />

<h2>Lista en tiempo real</h2>
<ul id="productsList"></ul>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/realTime.js"></script>



